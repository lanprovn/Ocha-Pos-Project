{
  "name": "ocha-pos-backend",
  "version": "1.0.0",
  "description": "Backend API for OCHA POS System",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-port.ps1 && npm run dev",
    "build": "npm run prisma:generate && tsc",
    "start": "node dist/server.js",
    "start:prod": "npm run prisma:migrate:deploy && npm run check:dist && node start-server.js",
    "test:node": "node -e \"console.log('Node.js is working'); process.exit(0);\"",
    "check:dist": "node -e \"const fs = require('fs'); console.log('dist/server.js exists:', fs.existsSync('dist/server.js')); if (fs.existsSync('dist/server.js')) { console.log('File size:', fs.statSync('dist/server.js').size, 'bytes'); }\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration"
  },
  "keywords": [
    "pos",
    "backend",
    "api",
    "express",
    "typescript"
  ],
  "author": "Lan Pro <lanprovn@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/uuid": "^10.0.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.0",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.0.2",
    "socket.io": "^4.8.1",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/winston": "^2.4.4",
    "jest": "^29.7.0",
    "nodemon": "^2.0.22",
    "prisma": "^5.0.0",
    "supertest": "^6.3.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
